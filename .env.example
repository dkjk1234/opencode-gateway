# Server
YOURSERVICE_GATEWAY_HOST=127.0.0.1
YOURSERVICE_GATEWAY_PORT=8788

# Development token balances. Comma separated token:credit pairs.
# Example: dev-token:100000,team-token:250000
YOURSERVICE_DEV_TOKENS=dev-token:100000

# Set true only for local throwaway tests.
YOURSERVICE_ALLOW_ANON_DEV=false
YOURSERVICE_ALLOW_DEV_APPROVAL=false

# Basic no-dependency safety limits.
YOURSERVICE_MAX_BODY_BYTES=1000000
YOURSERVICE_RATE_LIMIT_PER_MINUTE=120
YOURSERVICE_RATE_LIMIT_DISABLED=false

# Optional local admin credit grants. Leave empty to disable /admin/*.
YOURSERVICE_ADMIN_TOKEN=
YOURSERVICE_MAX_CREDIT_GRANT=1000000

# Upstream provider settings. Do not ship provider keys to the desktop app.
# mock keeps the gateway fully local. openai forwards to an OpenAI-compatible /chat/completions API.
YOURSERVICE_UPSTREAM_MODE=mock
UPSTREAM_OPENAI_API_KEY=
UPSTREAM_OPENAI_BASE_URL=https://api.openai.com/v1
UPSTREAM_OPENAI_MODEL=
UPSTREAM_OPENAI_FAST_MODEL=
UPSTREAM_OPENAI_PRO_MODEL=
UPSTREAM_OPENAI_ORG_ID=
UPSTREAM_OPENAI_PROJECT_ID=
UPSTREAM_OPENAI_TIMEOUT_MS=120000
