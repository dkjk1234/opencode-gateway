# Server
YOURSERVICE_GATEWAY_HOST=127.0.0.1
YOURSERVICE_GATEWAY_PORT=8788
# Many hosts such as Render/Railway/Fly inject PORT; if set, it overrides YOURSERVICE_GATEWAY_PORT.
PORT=
YOURSERVICE_PUBLIC_BASE_URL=http://127.0.0.1:8788
# Optional when publishing below a path, e.g. https://llms.ai.kr/opencode-gateway.
YOURSERVICE_BASE_PATH=
YOURSERVICE_DATA_PATH=.data/gateway-state.json

# Development token balances. Comma separated token:credit pairs.
# Example: dev-token:100000,team-token:250000
YOURSERVICE_DEV_TOKENS=dev-token:100000

# Set true only for local throwaway tests.
YOURSERVICE_ALLOW_ANON_DEV=false
YOURSERVICE_ALLOW_DEV_APPROVAL=false

# Optional production OAuth/OIDC login for the /login and /activate device approval frontend.
# You can provide either YOURSERVICE_OAUTH_ISSUER for OIDC discovery or explicit endpoint URLs.
YOURSERVICE_OAUTH_PROVIDER=google
YOURSERVICE_OAUTH_ISSUER=https://accounts.google.com
YOURSERVICE_OAUTH_AUTHORIZATION_URL=
YOURSERVICE_OAUTH_TOKEN_URL=
YOURSERVICE_OAUTH_USERINFO_URL=
YOURSERVICE_OAUTH_CLIENT_ID=
YOURSERVICE_OAUTH_CLIENT_SECRET=
YOURSERVICE_OAUTH_REDIRECT_URI=https://llms.ai.kr/opencode-gateway/auth/oauth/callback
YOURSERVICE_OAUTH_SCOPE=openid email profile
YOURSERVICE_OAUTH_INITIAL_CREDITS=0

# Optional Stripe webhook for credit grants. Keep the webhook secret server-side.
YOURSERVICE_BILLING_PROVIDER=stripe
YOURSERVICE_BILLING_PLANS_JSON=[{"id":"starter","name":"Starter credits","credits":100000,"amount":990,"currency":"usd"}]
YOURSERVICE_BILLING_SUCCESS_URL=
YOURSERVICE_BILLING_CANCEL_URL=
YOURSERVICE_STRIPE_SECRET_KEY=
YOURSERVICE_STRIPE_API_BASE_URL=https://api.stripe.com
YOURSERVICE_STRIPE_WEBHOOK_SECRET=
YOURSERVICE_STRIPE_SIGNATURE_TOLERANCE_SECONDS=300
YOURSERVICE_STRIPE_MAX_CREDIT_GRANT=1000000

# Production DB target. Use json locally or postgres with DATABASE_URL for deployed persistence.
YOURSERVICE_STATE_BACKEND=json
DATABASE_URL=
YOURSERVICE_POSTGRES_SSL=
YOURSERVICE_POSTGRES_AUTO_MIGRATE=true
YOURSERVICE_POSTGRES_POOL_MAX=5
YOURSERVICE_POSTGRES_SNAPSHOT_ID=default

# Basic no-dependency safety limits.
YOURSERVICE_MAX_BODY_BYTES=1000000
YOURSERVICE_RATE_LIMIT_PER_MINUTE=120
YOURSERVICE_RATE_LIMIT_DISABLED=false

# Optional local admin credit grants. Leave empty to disable /admin/*.
YOURSERVICE_ADMIN_TOKEN=
YOURSERVICE_MAX_CREDIT_GRANT=1000000

# Upstream provider settings. Do not ship provider keys to the desktop app.
# mock keeps the gateway fully local.
# openai forwards to an OpenAI-compatible /chat/completions API.
# codex-responses forwards Chat Completions requests to a Codex/OpenAI Responses-compatible /responses API.
YOURSERVICE_UPSTREAM_MODE=mock
UPSTREAM_OPENAI_API_KEY=
UPSTREAM_OPENAI_BASE_URL=https://api.openai.com/v1
UPSTREAM_OPENAI_MODEL=
UPSTREAM_OPENAI_FAST_MODEL=
UPSTREAM_OPENAI_PRO_MODEL=
UPSTREAM_OPENAI_ORG_ID=
UPSTREAM_OPENAI_PROJECT_ID=
UPSTREAM_OPENAI_TIMEOUT_MS=120000
